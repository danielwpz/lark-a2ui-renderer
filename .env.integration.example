# Copy this file to .env.integration and fill in real values.
# .env.integration is ignored by git.

# Enable real LLM integration tests.
RUN_A2UI_LLM_INTEGRATION=0

# OpenAI-compatible chat completions endpoint.
A2UI_LLM_API_KEY=
A2UI_LLM_MODEL=google/gemini-3-flash-preview
A2UI_LLM_BASE_URL=https://openrouter.ai/api/v1
# A2UI_LLM_CHAT_COMPLETIONS_URL=https://example.com/v1/chat/completions

# Enable real Feishu/Lark integration tests.
RUN_LARK_A2UI_INTEGRATION=0

# Feishu/Lark app credentials and target chat.
LARK_APP_ID=
LARK_APP_SECRET=
LARK_CHAT_ID=

# Optional Feishu/Lark SDK module override.
LARK_NODE_SDK_MODULE=@larksuiteoapi/node-sdk

# Fixture and render options.
LARK_A2UI_FIXTURE=confirm-button
# LARK_A2UI_SURFACE_ID=confirm_order
LARK_A2UI_PRINT_CARD_JSON=0

# Matrix integration options. The Lark integration test sends 50+ generated
# cards by default. Set a regex filter to rerun a single case or subset.
# LARK_A2UI_MATRIX_FILTER=deployment_review
LARK_A2UI_SEND_DELAY_MS=100

# Callback logging options. Set to 1 when you want to click manually and capture
# a real card.action.trigger payload.
LARK_A2UI_LISTEN_CALLBACKS=0
LARK_A2UI_CALLBACK_TIMEOUT_MS=180000
